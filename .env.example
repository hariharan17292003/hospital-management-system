# Copy this file to .env in the hms/ directory and fill in real values.

DJANGO_SECRET_KEY=change-me-to-a-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=hms_db
DB_USER=hms_user
DB_PASSWORD=hms_password
DB_HOST=localhost
DB_PORT=5432

TIME_ZONE=Asia/Kolkata

# Serverless email microservice (see ../email-service)
EMAIL_SERVICE_BASE_URL=http://localhost:3000/dev
EMAIL_SERVICE_SHARED_SECRET=
EMAIL_SERVICE_FAIL_SILENTLY=True

# Google Calendar OAuth2 -- from Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/calendar/oauth2/callback/
